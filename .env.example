# Statistical Arbitrage Simulator - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# DATA SETTINGS
# =============================================================================
TICKERS=AAPL,MSFT,GOOGL,AMZN,META,JPM,V,UNH,NVDA,HD
START_DATE=2022-01-01
END_DATE=2024-01-01

# =============================================================================
# TRADING STRATEGY PARAMETERS
# =============================================================================
P_VALUE_THRESHOLD=0.05
ZSCORE_WINDOW=30
ENTRY_Z=1.0
EXIT_Z=0.5
INITIAL_CAPITAL=10000

# =============================================================================
# FILE PATHS
# =============================================================================
PRICE_DATA_PATH=data/price_data.csv
ZSCORE_OUTPUT_PATH=data/zscore_signals.csv

# =============================================================================
# API KEYS - REQUIRED FOR CERTAIN FEATURES
# =============================================================================
# OpenAI API key (optional - for future AI features)
OPENAI_API_KEY=

# =============================================================================
# DATABASE
# =============================================================================
# SQLite (default) or PostgreSQL connection string
DATABASE_URL=sqlite:///data/arbitrage.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/arbitrage

# =============================================================================
# AUTHENTICATION
# =============================================================================
AUTH_ENABLED=false
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-secure-random-key

# =============================================================================
# EMAIL NOTIFICATIONS (optional)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL=

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
DEBUG=false
LOG_LEVEL=INFO
